{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/webhook/[webhook_url]",
      "regex": "^/api/webhook/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPwebhook_url": "nxtPwebhook_url"
      },
      "namedRegex": "^/api/webhook/(?<nxtPwebhook_url>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/insights",
      "regex": "^/dashboard/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/insights(?:/)?$"
    },
    {
      "page": "/dashboard/matchmaking",
      "regex": "^/dashboard/matchmaking(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/matchmaking(?:/)?$"
    },
    {
      "page": "/dashboard/member-portal",
      "regex": "^/dashboard/member\\-portal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/member\\-portal(?:/)?$"
    },
    {
      "page": "/dashboard/members",
      "regex": "^/dashboard/members(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/members(?:/)?$"
    },
    {
      "page": "/dashboard/moderation",
      "regex": "^/dashboard/moderation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/moderation(?:/)?$"
    },
    {
      "page": "/dashboard/settings",
      "regex": "^/dashboard/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/onboarding/community",
      "regex": "^/onboarding/community(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/onboarding/community(?:/)?$"
    },
    {
      "page": "/signup",
      "regex": "^/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signup(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}